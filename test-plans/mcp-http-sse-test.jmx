<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="MCPulse - HTTP+SSE MCP Smoke" enabled="true">
      <stringProp name="TestPlan.comments">Single-thread sanity check for HTTP+SSE transport</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
    </TestPlan>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="HTTP+SSE 1-thread">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">stoptest</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <io.github.mcpsampler.McpSampler guiclass="io.github.mcpsampler.gui.McpSamplerGui" testclass="io.github.mcpsampler.McpSampler" testname="tools/list (HTTP+SSE)" enabled="true">
          <stringProp name="McpSampler.transport">http+sse</stringProp>
          <stringProp name="McpSampler.httpBaseUrl">http://127.0.0.1:18080</stringProp>
          <stringProp name="McpSampler.httpSendPath">/message</stringProp>
          <stringProp name="McpSampler.ssePath">/events</stringProp>
          <stringProp name="McpSampler.sseCorrelationKey">id</stringProp>
          <stringProp name="McpSampler.sseConnectMode">per-thread</stringProp>
          <stringProp name="McpSampler.warmupMode">process</stringProp>
          <stringProp name="McpSampler.method">tools/list</stringProp>
          <stringProp name="McpSampler.clientName">mcpulse-http-sse</stringProp>
          <stringProp name="McpSampler.clientVersion">1.0.0</stringProp>
          <intProp name="McpSampler.timeoutMs">10000</intProp>
          <stringProp name="McpSampler.command">uvx</stringProp>
          <stringProp name="McpSampler.args"></stringProp>
          <stringProp name="McpSampler.rawRequestJson">{&quot;jsonrpc&quot;:&quot;2.0&quot;,&quot;method&quot;:&quot;tools/list&quot;}</stringProp>
          <stringProp name="McpSampler.toolName"></stringProp>
          <stringProp name="McpSampler.toolArgsJson">{}</stringProp>
          <intProp name="McpSampler.maxResponseBytes">65536</intProp>
          <stringProp name="McpSampler.validationMode">none</stringProp>
          <stringProp name="McpSampler.validationExpr"></stringProp>
          <stringProp name="McpSampler.validationExpected"></stringProp>
          <stringProp name="McpSampler.httpHeaders"></stringProp>
          <stringProp name="McpSampler.httpAuthType">none</stringProp>
          <stringProp name="McpSampler.httpBearerToken"></stringProp>
          <stringProp name="McpSampler.httpBasicUser"></stringProp>
          <stringProp name="McpSampler.httpBasicPass"></stringProp>
          <stringProp name="McpSampler.httpTlsMode">system</stringProp>
          <stringProp name="McpSampler.httpTruststorePath"></stringProp>
          <stringProp name="McpSampler.httpTruststorePassword"></stringProp>
          <stringProp name="McpSampler.sseEventFilter"></stringProp>
          <boolProp name="McpSampler.debugTransport">false</boolProp>
        </io.github.mcpsampler.McpSampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert tools/list response code is 200 (HTTP+SSE)">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert tools/list contains echo (HTTP+SSE)">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="3107365">echo</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
